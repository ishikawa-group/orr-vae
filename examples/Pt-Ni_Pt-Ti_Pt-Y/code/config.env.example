# Job / random seed
JOB_NUM=manual
SEED=0

# VAE / training
LABEL_THRESHOLD=0.3
BATCH_SIZE=16
MAX_EPOCH=200
LATENT_SIZE=32
BETA=1
MAX_ITER=5

# ORR backend
CALCULATOR=fairchem

# Structure counts (requirement)
INITIAL_NUM_STRUCTURES=255
GENERATED_NUM_STRUCTURES=255

# Slab shape
GRID_X=4
GRID_Y=4
GRID_Z=6

# Optional toggles
WITH_VISUALIZATION=1
WITH_ANALYSIS=1
