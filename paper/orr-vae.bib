@article{hisamaTheoreticalCatalystScreening2024,
  title = {Theoretical {{Catalyst Screening}} of {{Multielement Alloy Catalysts}} for {{Ammonia Synthesis Using Machine Learning Potential}} and {{Generative Artificial Intelligence}}},
