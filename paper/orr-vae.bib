@article{sharmaMachineLearningGuidedDiscovery2025,
  title = {Machine {{Learning-Guided Discovery}} of {{Alloy Nanoclusters}}: {{Steering Morphology-Based Activity}} and {{Selectivity Relationships}} in {{Bifunctional Electrocatalysts}}},
  shorttitle = {Machine {{Learning-Guided Discovery}} of {{Alloy Nanoclusters}}},
  author = {Sharma, Rahul Kumar and Minhas, Harpriya and Pathak, Biswarup},
  date = {2025-07-16},
  journaltitle = {ACS Applied Materials \& Interfaces},
